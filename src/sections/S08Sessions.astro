---
/*
 * S08Sessions.astro — Sessions section
 *
 * Two-zone layout (iyo-clean pattern):
 *   Entry:  Eyebrow "SESSIONS" (azure) + BlurReveal headline + lead
 *   Body:   4 lifecycle phases (NumberedRows) — Create, Initialize, Execute, Cleanup
 *           "Parent and child sessions" — parent_id and kernel contract
 *           "Cancellation" — cooperative flag model
 *
 * background="void"   mode="technical" (azure eyebrow)
 * Content sourced from: .design/sections/08-sessions.md
 */
import Section from '../components/sections/Section.astro';
import Eyebrow from '../components/content/Eyebrow.astro';
import BlurReveal from '../components/content/BlurReveal.astro';
import NumberedRow from '../components/content/NumberedRow.astro';
import UpNextTeaser from '../components/content/UpNextTeaser.astro';
---

<Section id="s8" label="Sessions" background="void">
  <Fragment slot="entry">
    <Eyebrow label="SESSIONS" mode="technical" />
    <BlurReveal>
      <h2>A session is a container.</h2>
    </BlurReveal>
    <p class="lead">
      A session is the container around one instance of the system running. In the CLI, a
      session is a conversation. In a pipeline runner, a session is a single batch execution.
      In the kernel, a session is just an ID and a lifecycle.
    </p>
  </Fragment>

  <!-- ── Lifecycle phases ──────────────────────────────────────────────────── -->
  <div class="lifecycle">
    <NumberedRow
      number="01"
      label="Create"
      description="Session created with configuration. Coordinator and Module Loader are set up. Nothing has been loaded yet."
    />
    <NumberedRow
      number="02"
      label="Initialize"
      description="Module Loader loads modules in fixed order. If the Orchestrator or Context Manager fails to load, the session stops. Everything else is optional."
    />
    <NumberedRow
      number="03"
      label="Execute"
      description="Session receives a message. Passes it to the Orchestrator. Gets a response back. This phase is repeatable. Each call is one turn of conversation."
    />
    <NumberedRow
      number="04"
      label="Cleanup"
      description="session:end fires first (hooks get a final chance). Then Coordinator cleans up modules. Then Loader cleans up. In a finally block. Always runs, even after errors."
    />
  </div>

  <!-- ── Parent and child sessions ────────────────────────────────────────── -->
  <div class="subsection">
    <h3>Parent and child sessions</h3>
    <p>
      The core provides a parent_id field that links one session to another. That is the
      extent of what the kernel does. How parent-child relationships are used (delegation,
      sub-agents, task decomposition) is decided by Foundation and applications built on
      top of it.
    </p>
  </div>

  <!-- ── Cancellation ──────────────────────────────────────────────────────── -->
  <div class="subsection">
    <h3>Cancellation</h3>
    <p>
      Cancellation is cooperative. The kernel can't forcibly stop an Orchestrator in the
      middle of its work. Instead, it sets a flag with three states: no cancellation
      requested, graceful cancellation (finish what you're doing), and immediate cancellation
      (stop as soon as possible). The Orchestrator must check this flag periodically. If it
      ignores the flag, cancellation doesn't happen.
    </p>
  </div>

  <img
    src={`${import.meta.env.BASE_URL}diagrams/session-tree.svg`}
    alt="Session tree: parent session spawning isolated child sessions"
    class="diagram"
  />

  <UpNextTeaser
    nextSection="Bundles"
    teaser="Bundles are how you package and distribute capabilities."
  />
</Section>

<style>
  /* ── Entry zone ───────────────────────────────────────────────────────────── */

  h2 {
    max-width: 20ch;
  }

  .lead {
    font-size: clamp(1.125rem, 1.2vw, 1.25rem);
    line-height: var(--leading-relaxed);
    color: var(--text-body);
    max-width: 55ch;
    margin-top: var(--space-4);
  }

  /* ── Lifecycle phases ─────────────────────────────────────────────────────── */

  .lifecycle {
    max-width: 60ch;
  }

  /* ── Sub-sections (parent/child + cancellation) ───────────────────────────── */

  .subsection {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 60ch;
    color: var(--text-body);
    margin-top: var(--space-6);
  }

  .subsection h3 {
    font-size: var(--text-body);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-1);
  }

  .subsection p {
    line-height: var(--leading-normal);
  }

  /* ── Diagram ──────────────────────────────────────────────────────────────── */
  .diagram {
    display: block;
    width: 100%;
    max-width: 600px;
    margin: var(--space-8) 0;
    opacity: 0.9;
  }
</style>
