---
/*
 * S02ArchitectureMap.astro — Architecture Map section
 *
 * Technical mode: void ground, azure eyebrow, Lora h2.
 * iyo-clean two-zone pattern via Section.astro's entry/content slots.
 *
 * Entry slot (min-height: 100vh, ~85% negative space):
 *   Eyebrow (technical/azure) → BlurReveal(h2) → lead paragraph
 *
 * Default slot (body below the entry viewport):
 *   2 paragraphs → architecture-stack.svg diagram → 5 NumberedRows → UpNextTeaser
 *
 * Content sourced from: .design/sections/02-architecture-map.md
 */
import Section from '../components/sections/Section.astro';
import Eyebrow from '../components/content/Eyebrow.astro';
import BlurReveal from '../components/content/BlurReveal.astro';
import NumberedRow from '../components/content/NumberedRow.astro';
import UpNextTeaser from '../components/content/UpNextTeaser.astro';
---

<Section id="s2" label="Architecture Map" background="void">

  <Fragment slot="entry">
    <div class="s02-entry">
      <Eyebrow label="ARCHITECTURE MAP" />
      <BlurReveal>
        <h2 class="s02-entry__headline">
          A map of the territory before we walk through it.
        </h2>
      </BlurReveal>
      <p class="s02-entry__lead">
        This diagram shows every major component and how they connect. Think of it as a city map before you walk the streets. You don't need to know every building. You need the neighborhoods.
      </p>
    </div>
  </Fragment>

  <!-- Body content — paragraphs then numbered rows -->
  <div class="s02-body">
    <p>
      The most important cluster is at the center: amplifier-core. Everything else depends on it; it depends on nothing. That asymmetry is the architecture in one sentence.
    </p>

    <p>
      Don't try to memorize the diagram. Use it as a reference. As we walk through each piece in the sections that follow, this map will make more sense. By the time we reach the final section, every cluster will be familiar.
    </p>
  </div>

  <img
    src={`${import.meta.env.BASE_URL}diagrams/architecture-stack.svg`}
    alt="Five-layer architecture stack: Kernel, Modules, Foundation, Applications, Bundles"
    class="diagram"
  />

  <div class="s02-rows">
    <NumberedRow
      number="01"
      label="Kernel"
      description="amplifier-core. ~2,600 lines. Session lifecycle, module loading, event dispatch."
    />
    <NumberedRow
      number="02"
      label="Modules"
      description="Five types: Provider, Tool, Orchestrator, Context, Hook. Each one replaceable."
    />
    <NumberedRow
      number="03"
      label="Foundation"
      description="amplifier-foundation. Bundle primitives, shared utilities, reference bundles."
    />
    <NumberedRow
      number="04"
      label="Applications"
      description="amplifier-app-cli and custom apps. Built on foundation, never on kernel directly."
    />
    <NumberedRow
      number="05"
      label="Bundles"
      description="Composable configuration packages. No runtime code, only composition."
    />
  </div>

  <UpNextTeaser
    nextSection="Design Philosophy"
    teaser="Three ideas shape how Amplifier is built."
  />

</Section>

<style>
  /* ── Entry cluster ──────────────────────────────────────────────────────────
   * Technical entry: azure eyebrow (handled by Eyebrow mode="technical"),
   * Lora h2 at --text-h2 scale, Inter lead at 75% opacity.
   * ─────────────────────────────────────────────────────────────────────────── */
  .s02-entry {
    display: flex;
    flex-direction: column;
  }

  .s02-entry :global(.blur-reveal) {
    margin-bottom: var(--space-3); /* 24px: headline → lead */
  }

  .s02-entry__headline {
    font-family: var(--font-serif);        /* Lora — Voice of Ideas */
    font-size: var(--text-h2);             /* clamp(1.5rem, 2.5vw, 2.25rem) */
    font-weight: 600;
    line-height: var(--leading-tight);     /* 1.15 */
    letter-spacing: var(--tracking-tight); /* -0.02em */
    color: var(--text-primary);            /* #FAFAF8 */
    max-width: 22ch;
    margin: 0;
  }

  .s02-entry__lead {
    font-family: var(--font-sans);
    font-size: clamp(1.125rem, 1.2vw, 1.25rem);
    font-weight: 400;
    line-height: var(--leading-relaxed);   /* 1.8 */
    color: var(--text-body);
    opacity: 0.75;
    max-width: 55ch;
    margin: 0;
  }

  /* ── Body paragraphs ─────────────────────────────────────────────────────────
   * Technical section: tighter leading (1.6), reader is scanning structure.
   * em for inline code identifiers renders in --text-primary.
   * ─────────────────────────────────────────────────────────────────────────── */
  .s02-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);           /* 24px between paragraphs */
    max-width: 60ch;
    color: var(--text-body);
  }

  .s02-body p {
    line-height: var(--leading-normal); /* 1.6 — technical section */
    margin: 0;
  }

  .s02-body em {
    font-style: italic;
    color: var(--text-primary);
  }

  /* ── Numbered rows ───────────────────────────────────────────────────────────
   * Top border opens the list cleanly. No gap between rows —
   * NumberedRow component handles its own internal padding/border.
   * ─────────────────────────────────────────────────────────────────────────── */
  .s02-rows {
    display: flex;
    flex-direction: column;
    max-width: 60ch;
    border-top: 1px solid var(--divider);
    margin-top: var(--space-3);    /* 24px gap from last paragraph */
  }

  /* ── Diagram ─────────────────────────────────────────────────────────────────*/
  .diagram {
    display: block;
    width: 100%;
    max-width: 600px;
    margin: var(--space-8) 0;
    opacity: 0.9;
  }
</style>
