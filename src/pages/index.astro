---
import MasterclassLayout from '../layouts/MasterclassLayout.astro';
import S01Introduction from '../sections/S01Introduction.astro';
import Section from '../components/sections/Section.astro';
import { sections } from '../data/sections';

// Background mapping per design doc:
// s3, s12 = palette-break; s5, s7, s9, s11 = secondary-dark; rest = primary-dark
const bgMap: Record<string, string> = {
  s3: 'palette-break',
  s12: 'palette-break',
  s5: 'secondary-dark',
  s7: 'secondary-dark',
  s9: 'secondary-dark',
  s11: 'secondary-dark',
};

const placeholderSections = sections
  .filter((s) => s.id !== 's1')
  .map((s) => ({
    ...s,
    background: bgMap[s.id] ?? 'primary-dark',
  }));
---

<MasterclassLayout title="Amplifier Masterclass">
  <!-- Real content: Introduction -->
  <S01Introduction />

  <!-- Placeholder sections for s2-s13 so TOC tracking works -->
  {placeholderSections.map((section) => (
    <Section id={section.id} label={section.label} background={section.background}>
      <h2>{section.label}</h2>
      <p style="color: var(--text-muted); font-style: italic;">
        Content coming in Phase 2.
      </p>
    </Section>
  ))}
</MasterclassLayout>
