---
/*
 * TopNav.astro — Transparent → frosted glass top navigation
 *
 * Behavior (from lookbook site 18 / iyo.ai pattern):
 *   1. Starts completely transparent. The page breathes around it.
 *   2. After 80px of scroll: frosted glass appears (rgba(15,15,19,0.85) + blur(16px)).
 *      A subtle border-bottom materializes from nothing.
 *   3. On parchment sections (S03, S12): overrides to dark glass
 *      (rgba(26,24,21,0.85)). White text remains readable above the
 *      warm cream background because the nav creates its own dark panel.
 *
 * Anatomy (left → center → right):
 *   Left:   "Amplifier" wordmark — Space Grotesk 500, small-caps, 0.15em tracking,
 *           muted color (rgba(255,255,255,0.4)). Links to withamplifier.com.
 *   Center: Current section name — Inter 400, 13px, fades in/out on section change.
 *           Empty at the very top of the page.
 *   Right:  Mobile TOC toggle button — hidden on desktop (≥1025px).
 *           Shows a compact section list; closes on any link click.
 *
 * Removed from the previous build:
 *   - "Presentation Mode · 72 slides" label (not part of the reading experience)
 *
 * Height: 56px (hard value — not spacing token)
 * z-index: --z-topnav (30)
 */
import { sections } from '../../data/sections';
---

<header class="topnav" aria-label="Site navigation">
  <div class="topnav__inner">

    <!-- Left: Wordmark -->
    <a
      href="https://withamplifier.com"
      class="topnav__wordmark"
      target="_blank"
      rel="noopener"
      aria-label="Amplifier — opens withamplifier.com"
    >
      Amplifier
    </a>

    <!-- Center: Current section label (updated by JS) -->
    <span class="topnav__section-label" aria-live="polite" aria-atomic="true"></span>

    <!-- Right: Mobile TOC toggle (desktop: hidden) -->
    <button
      class="topnav__toc-btn"
      aria-expanded="false"
      aria-controls="mobile-toc"
      aria-label="Open table of contents"
    >
      Contents
    </button>

  </div>

  <!-- Mobile TOC dropdown -->
  <nav class="topnav__mobile-toc" id="mobile-toc" aria-label="Table of Contents" hidden>
    <ul class="topnav__mobile-list">
      {sections.map(section => (
        <li class="topnav__mobile-item" data-section-id={section.id}>
          <a href={`#${section.id}`} class="topnav__mobile-link">
            {section.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  /* ── Base: always transparent at rest ─────────────────────────────────── */
  .topnav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 56px;
    z-index: var(--z-topnav); /* 30 */

    /* Base: fully transparent — the page breathes around it */
    background: transparent;
    border-bottom: 1px solid transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;

    /* Smooth transitions for all visual state changes */
    transition:
      background    var(--duration-normal) var(--ease-default),
      border-color  var(--duration-normal) var(--ease-default),
      backdrop-filter var(--duration-normal) var(--ease-default);
  }

  /* ── Scrolled: frosted glass (dark sections) ──────────────────────────── */
  /*
   * Activated by JS after 80px of scroll.
   * rgba(15,15,19,0.85) = void color at 85% opacity — barely-there dark panel.
   * blur(16px) is more aggressive than glass cards (10px) because this is
   * an interactive surface floating over the full page width.
   */
  .topnav.is-scrolled {
    background: rgba(15, 15, 19, 0.85); /* --bg-void at 85% */
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ── Parchment override: LIGHT frosted glass on cream background ───── */
  /*
   * S03 and S12 use parchment (#F5F3EC). Instead of a dark alien bar
   * floating over cream, the nav progressively switches to a light theme:
   * frosted cream glass, dark text, warm border. CSS transitions on all
   * properties handle the progressive cross-fade between dark ↔ light.
   */
  .topnav.is-scrolled[data-parchment] {
    background: rgba(245, 243, 236, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  /* ── Parchment: text colors flip to dark (scrolled or not) ────────── */
  .topnav[data-parchment] .topnav__wordmark {
    color: rgba(26, 24, 21, 0.45);
  }
  .topnav[data-parchment] .topnav__wordmark:hover {
    color: rgba(26, 24, 21, 0.70);
  }
  .topnav[data-parchment] .topnav__section-label {
    color: rgba(26, 24, 21, 0.60);
  }
  .topnav[data-parchment] .topnav__toc-btn {
    color: rgba(26, 24, 21, 0.50);
    border-color: rgba(26, 24, 21, 0.15);
  }
  .topnav[data-parchment] .topnav__toc-btn:hover {
    color: rgba(26, 24, 21, 0.80);
    border-color: rgba(26, 24, 21, 0.30);
  }

  /* ── Inner layout ──────────────────────────────────────────────────────── */
  .topnav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    max-width: var(--content-full); /* 1200px */
    margin: 0 auto;
    padding: 0 var(--space-4); /* 0 32px */
  }

  /* ── Wordmark: Space Grotesk small-caps ───────────────────────────────── */
  /*
   * "Amplifier" written in mixed case, rendered as small-caps:
   * A (normal size) + mplifier (small uppercase version).
   * 0.15em tracking expands the letterforms for authority and legibility.
   * Muted color: the wordmark is a landmark, not a headline — it should
   * be findable but never compete with the content.
   */
  .topnav__wordmark {
    font-family: var(--font-mono);        /* Space Grotesk — Voice of Precision */
    font-size: 13px;                      /* --text-nav per style-seed */
    font-weight: 500;
    font-variant-caps: small-caps;        /* Lowercase → small uppercase forms */
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.40);    /* --text-muted approximate */
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--duration-fast) var(--ease-default);
  }

  .topnav__wordmark:hover {
    color: rgba(255, 255, 255, 0.65);
  }

  /* ── Section label: Inter 400, centered ──────────────────────────────── */
  /*
   * Shows the name of the currently-visible section. Updated by JS via
   * a subtle cross-fade (opacity 0 → update text → opacity 1).
   * Uses aria-live="polite" so screen readers announce the section change.
   */
  .topnav__section-label {
    font-family: var(--font-sans);  /* Inter — Voice of Structure */
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0;
    /* Center in the flex row by taking up flexible space */
    flex: 1;
    text-align: center;
    padding: 0 var(--space-3);
    /* Fade + color transition for cross-dissolve and parchment switch */
    transition:
      opacity var(--duration-fast) var(--ease-default),
      color   var(--duration-normal) var(--ease-default);
    /* Truncate long section names */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Mobile TOC button: hidden on desktop ─────────────────────────────── */
  .topnav__toc-btn {
    display: none; /* Desktop: sidebar handles TOC */
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.50);
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 4px;           /* --glass-radius-small */
    padding: 4px var(--space-2);  /* 4px 16px */
    cursor: pointer;
    white-space: nowrap;
    transition:
      color        var(--duration-fast) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default);
  }

  .topnav__toc-btn:hover {
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.25);
  }

  /* ── Mobile TOC dropdown ──────────────────────────────────────────────── */
  .topnav__mobile-toc {
    padding: var(--space-2) var(--space-4);
    background: rgba(15, 15, 19, 0.96);  /* More opaque than nav bar — this is a panel */
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .topnav__mobile-toc[hidden] {
    display: none;
  }

  .topnav__mobile-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .topnav__mobile-link {
    display: block;
    padding: var(--space-1) 0; /* 8px vertical breathing room per item */
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.50);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-default);
  }

  .topnav__mobile-link:hover {
    color: var(--text-primary);
  }

  /* Active mobile item */
  .topnav__mobile-item.is-active > .topnav__mobile-link {
    color: var(--accent); /* Azure */
    font-weight: 500;
  }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .topnav__toc-btn {
      display: inline-flex;
      align-items: center;
    }
  }
</style>

<script>
  const topnav = document.querySelector<HTMLElement>('.topnav');
  const sectionLabel = document.querySelector<HTMLElement>('.topnav__section-label');
  const tocBtn = document.querySelector<HTMLButtonElement>('.topnav__toc-btn');
  const mobileToc = document.querySelector<HTMLElement>('.topnav__mobile-toc');
  const mobileItems = document.querySelectorAll<HTMLElement>('.topnav__mobile-item');
  const sections = document.querySelectorAll<HTMLElement>('[data-section]');

  // Parchment sections: warm cream background — nav needs dark glass override
  const PARCHMENT_SECTIONS = new Set(['s3', 's12']);

  // ── All topnav-dependent logic ─────────────────────────────────────────
  //
  // Wrapped in a guard block (no top-level returns allowed in ES modules).
  if (topnav) {

    // ── Scroll → frosted glass ───────────────────────────────────────────
    //
    // 80px threshold: generous enough that the hero section fully owns the
    // viewport before the nav materializes. Passive listener for perf.
    const SCROLL_THRESHOLD = 80;

    window.addEventListener(
      'scroll',
      () => {
        if (window.scrollY > SCROLL_THRESHOLD) {
          topnav.classList.add('is-scrolled');
        } else {
          topnav.classList.remove('is-scrolled');
        }
      },
      { passive: true }
    );

    // ── Section label cross-fade ─────────────────────────────────────────
    //
    // Fades the center label out, updates the text, then fades back in.
    // Uses CSS opacity transition for the cross-dissolve effect.
    let labelFadeTimer: ReturnType<typeof setTimeout> | null = null;

    function setSectionLabel(text: string): void {
      if (!sectionLabel) return;
      if (labelFadeTimer) clearTimeout(labelFadeTimer);

      sectionLabel.style.opacity = '0';
      labelFadeTimer = setTimeout(() => {
        sectionLabel.textContent = text;
        sectionLabel.style.opacity = '1';
      }, 100);
    }

    // ── Section tracking ─────────────────────────────────────────────────
    if (sections.length > 0) {
      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const label = entry.target.getAttribute('data-label') ?? '';
              const sectionId = entry.target.getAttribute('data-section') ?? '';

              // Update center section label with cross-fade
              setSectionLabel(label);

              // Parchment detection: dark glass when on light-background sections
              if (PARCHMENT_SECTIONS.has(sectionId)) {
                topnav.setAttribute('data-parchment', '');
              } else {
                topnav.removeAttribute('data-parchment');
              }

              // Update mobile TOC active state
              mobileItems.forEach((item) => {
                item.classList.toggle(
                  'is-active',
                  item.getAttribute('data-section-id') === sectionId
                );
              });
            }
          });
        },
        { threshold: 0.2, rootMargin: '-10% 0px -70% 0px' }
      );

      sections.forEach((section) => sectionObserver.observe(section));
    }

  } // end if (topnav)

  // ── Mobile TOC toggle ──────────────────────────────────────────────────
  //
  // Standalone from topnav guard — tocBtn and mobileToc may exist
  // even if the topnav element query failed (shouldn't happen, but safe).
  if (tocBtn && mobileToc) {
    tocBtn.addEventListener('click', () => {
      const isOpen = !mobileToc.hidden;
      mobileToc.hidden = isOpen;
      tocBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    // Close dropdown when any link is tapped (navigates to anchor)
    mobileToc.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileToc.hidden = true;
        tocBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
