---
/*
 * ProgressBar.astro — Thin fixed bar at viewport top tracking scroll progress.
 *
 * Purely visual / decorative; hidden from assistive tech via aria-hidden.
 * Scroll position is computed client-side with a passive listener for
 * maximum performance — no layout thrash, no JS framework needed.
 */
---

<div class="progress-bar" aria-hidden="true">
  <div class="progress-bar__fill"></div>
</div>

<style>
  .progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: transparent;
    z-index: var(--z-progress); /* 40 — topmost */
    pointer-events: none;
  }

  .progress-bar__fill {
    height: 100%;
    width: 0%;
    background-color: var(--accent); /* Azure #0082EB */
    transition: width 50ms linear; /* Smooth but fast tracking */
  }
</style>

<script>
  const fill = document.querySelector('.progress-bar__fill');
  if (fill) {
    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      (fill as HTMLElement).style.width = `${progress}%`;
    }, { passive: true });
  }
</script>
