---
/*
 * ProgressBar.astro — Thin scroll-progress indicator at viewport top
 *
 * Design spec:
 *   - 2px tall, full viewport width
 *   - Azure (#0082EB) fill via --accent token
 *   - Sits at the very top of the stacking order (--z-progress: 40)
 *   - Completely transparent track (no background color on the container)
 *   - Pointer-events none: never intercepts interaction
 *
 * Implementation:
 *   - Passive scroll event listener — maximum performance, no layout thrash
 *   - Computes progress from scrollY relative to max scrollable height
 *   - 50ms linear transition on width for smooth visual tracking without lag
 *   - aria-hidden: purely decorative, not meaningful to assistive tech
 *
 * The progress bar sits above the TopNav (z-index 40 vs 30) so it's
 * always visible at the very top edge, even when the frosted glass nav
 * is present.
 */
---

<div class="progress-bar" aria-hidden="true" role="presentation">
  <div class="progress-bar__fill"></div>
</div>

<style>
  /* ── Track ─────────────────────────────────────────────────────────────── */
  .progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: transparent;   /* No visible track — fill appears from nothing */
    z-index: var(--z-progress); /* 40 — topmost layer */
    pointer-events: none;       /* Never intercepts interaction */
  }

  /* ── Fill ──────────────────────────────────────────────────────────────── */
  /*
   * Azure fill: --accent (#0082EB) is the sole signal color.
   * Progress bar is navigation — azure is correct here.
   * 50ms linear keeps it snappy and tracking without visible latency.
   * width is set by JS from 0% to 100% based on scroll position.
   */
  .progress-bar__fill {
    height: 100%;
    width: 0%;
    background-color: var(--accent); /* #0082EB azure */
    transition: width 50ms linear;
  }
</style>

<script>
  const fill = document.querySelector<HTMLElement>('.progress-bar__fill');

  if (fill) {
    function updateProgress(): void {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docHeight =
        document.documentElement.scrollHeight - window.innerHeight;
      // Guard division-by-zero on pages shorter than the viewport
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      fill!.style.width = `${Math.min(progress, 100)}%`;
    }

    // Passive listener: never blocks scroll events, won't cause jank
    window.addEventListener('scroll', updateProgress, { passive: true });

    // Run once on mount to handle cases where page loads mid-scroll
    // (e.g., browser restoring scroll position after navigation)
    updateProgress();
  }
</script>
