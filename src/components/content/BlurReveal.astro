---
/*
 * BlurReveal.astro — Staggered character blur-to-clear reveal on scroll
 *
 * Wraps any text content and animates it into view as the reader scrolls
 * past it. Each word enters individually with a staggered delay,
 * creating a left-to-right dissolution from blurred void into sharp text.
 * Words are preserved as whole units — never split mid-word.
 *
 * Based on lookbook site 64 pattern.
 *
 * Animation spec per character:
 *   Start:  opacity 0, translateY(18px), blur(12px)
 *   End:    opacity 1, translateY(0), blur(0)
 *   Timing: 550ms, cubic-bezier(0.22, 1, 0.36, 1)
 *   Stagger: 38ms per character
 *   Threshold: 0.15 (fires when 15% of element is visible)
 *
 * Handles <br>, <em>, <strong> by recursing into elements and only
 * splitting leaf text nodes — element structure is preserved.
 *
 * Respects prefers-reduced-motion: shows content immediately without
 * any character splitting or animation.
 *
 * Usage:
 *   <BlurReveal>
 *     Your <em>headline</em> text here.
 *   </BlurReveal>
 */
---

<div class="blur-reveal" data-blur-reveal>
  <slot />
</div>

<style>
  /*
   * The container itself is neutral — no layout changes.
   * All animation state lives on .blur-char spans injected by JS.
   */
  .blur-reveal {
    /* Isolate stacking context so blur doesn't bleed into surrounding elements */
    isolation: isolate;
  }

  /*
   * Character spans injected by JS.
   * inline-block is required for transform: translateY to take effect.
   * white-space: pre preserves spaces without collapsing them.
   */
  .blur-reveal :global(.blur-char) {
    display: inline-block;
    white-space: pre;   /* Prevent space collapse in inline-block context */
    opacity: 0;
    transform: translateY(18px);
    filter: blur(12px);
    /* Transition uses the settle easing — smooth deceleration into rest */
    transition:
      opacity  550ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 550ms cubic-bezier(0.22, 1, 0.36, 1),
      filter   550ms cubic-bezier(0.22, 1, 0.36, 1);
    /* Each character's delay is set inline via --delay custom property */
    transition-delay: var(--delay, 0ms);
    /* Keep hardware compositing layer consistent */
    will-change: opacity, transform, filter;
  }

  /*
   * .is-visible triggers via IntersectionObserver.
   * One-shot: added once, never removed (ink-on-paper permanence).
   */
  .blur-reveal.is-visible :global(.blur-char) {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /*
   * Reduced motion: override char spans to show immediately without any
   * animation. Content stays visible with zero transition.
   */
  @media (prefers-reduced-motion: reduce) {
    .blur-reveal :global(.blur-char) {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
      will-change: auto;
    }
  }
</style>

<script>
  /*
   * DOM traversal: recursively visits all descendant nodes of a container,
   * replacing leaf text nodes with per-character <span> elements.
   *
   * Element nodes (em, strong, span, etc.) are recursed into — their
   * structure is preserved, but their text children are split.
   *
   * <br> elements are skipped entirely (no recursion, no replacement).
   *
   * Returns the running character index so delays accumulate correctly
   * across nested elements.
   */
  function splitTextNodes(node: Node, wordIndex: number): number {
    if (node.nodeType === Node.TEXT_NODE) {
      const text = node.textContent ?? '';
      if (!text) return wordIndex;

      const fragment = document.createDocumentFragment();

      // Split on word boundaries, preserving spaces as part of the preceding word
      // This keeps whole words together so the blur reveal doesn't cut mid-word
      const words = text.match(/\S+\s*/g) || [];
      // Handle leading whitespace
      const leadingSpace = text.match(/^\s+/);
      if (leadingSpace) {
        const span = document.createElement('span');
        span.className = 'blur-char';
        span.style.setProperty('--delay', `${wordIndex * 60}ms`);
        span.textContent = leadingSpace[0];
        fragment.appendChild(span);
        wordIndex++;
      }

      for (const word of words) {
        const span = document.createElement('span');
        span.className = 'blur-char';
        span.style.setProperty('--delay', `${wordIndex * 60}ms`);
        span.textContent = word;
        fragment.appendChild(span);
        wordIndex++;
      }

      node.parentNode?.replaceChild(fragment, node);
      return wordIndex;

    } else if (node.nodeType === Node.ELEMENT_NODE) {
      const el = node as Element;

      // Skip <br> — leave in place, don't recurse
      if (el.tagName === 'BR') return charIndex;

      // Snapshot children first: iteration over childNodes mutates as we
      // replace text nodes, so we need a static array.
      const children = Array.from(el.childNodes);
      for (const child of children) {
        charIndex = splitTextNodes(child, charIndex);
      }

      return charIndex;
    }

    // Other node types (comments, CDATA, etc.) — skip
    return charIndex;
  }

  // ─── Initialization ─────────────────────────────────────────────────────────

  const prefersReducedMotion =
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const containers = document.querySelectorAll<HTMLElement>('[data-blur-reveal]');

  containers.forEach((container) => {
    // Reduced motion: skip all animation. Content renders immediately via CSS
    // (the @media block overrides char opacity/transform to show immediately).
    // No char splitting needed — raw slot content is already visible.
    if (prefersReducedMotion) return;

    // Split all text nodes in the container into per-character spans
    splitTextNodes(container, 0);

    // IntersectionObserver: fire once when 15% of the element enters the viewport
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          container.classList.add('is-visible');
          // One-shot: stop observing after reveal — content stays visible forever
          observer.unobserve(container);
        }
      },
      { threshold: 0.15 }
    );

    observer.observe(container);
  });
</script>
