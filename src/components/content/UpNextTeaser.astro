---
/*
 * UpNextTeaser.astro — Section transition element
 *
 * Subtle footer showing what's coming next in the masterclass.
 * Creates narrative momentum between sections.
 */
interface Props {
  nextSection: string;
  teaser: string;
}

const { nextSection, teaser } = Astro.props;
---

<div class="up-next">
  <span class="up-next__label">Next</span>
  <span class="up-next__section">{nextSection}</span>
  <span class="up-next__teaser">{teaser}</span>
</div>

<style>
  .up-next {
    margin-top: var(--space-12);
    padding-top: var(--space-4);
    border-top: 1px solid var(--divider);
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .up-next__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .up-next__section {
    font-family: var(--font-serif);
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--text-primary);
  }

  .up-next__teaser {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--text-muted);
    width: 100%;
  }
</style>
