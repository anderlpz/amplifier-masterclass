---
/*
 * UpNextTeaser.astro — Section transition element
 *
 * The "exhale" at the bottom of each section. Signals what's coming next
 * and creates narrative momentum as the reader scrolls toward it.
 *
 * Visual design:
 * - Appears in the final ~50vh of a section (layout responsibility of the parent)
 * - A very faint glass treatment (lighter than GlassCard — this is navigation-adjacent)
 * - Hairline top border separating it from body content
 * - "→" arrow before the next section name gives directional intent
 * - "Up next" label + section name + teaser text
 *
 * The glass is intentionally more recessive here than in GlassCard. The UpNext
 * teaser shouldn't demand attention — it should quietly invite the reader forward.
 *
 * Props:
 *   nextSection — name of the upcoming section
 *   teaser      — one-line description / thematic preview
 */
interface Props {
  nextSection: string;
  teaser: string;
}

const { nextSection, teaser } = Astro.props;
---

<div class="up-next">
  <div class="up-next__glass">
    <span class="up-next__label">Up next</span>

    <div class="up-next__name-row">
      <span class="up-next__arrow" aria-hidden="true">→</span>
      <span class="up-next__section">{nextSection}</span>
    </div>

    <p class="up-next__teaser">{teaser}</p>
  </div>
</div>

<style>
  /* ── Outer wrapper ─────────────────────────────────────────────────────── */
  .up-next {
    margin-top: var(--space-16); /* 128px — distance from body content */
    padding-top: var(--space-6); /* 48px — breathing room before the teaser */
    border-top: 1px solid var(--divider); /* Hairline separator */
  }

  /* ── Glass container ───────────────────────────────────────────────────── */
  /*
   * More recessive than GlassCard: 0.02 bg (vs 0.04), 0.04 border (vs 0.07).
   * The teasers are navigation-adjacent instruments, not content groupers.
   * They should feel like a quiet glass surface, not a prominent card.
   */
  .up-next__glass {
    display: inline-block;
    padding: var(--space-4); /* 32px */
    max-width: 55ch;          /* Comfortable reading width for the teaser text */
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 8px;
    /* No backdrop-filter — same rule as GlassCard: no blur behind content */
  }

  /* ── "Up next" label ───────────────────────────────────────────────────── */
  .up-next__label {
    display: block;
    font-family: var(--font-mono);  /* Space Grotesk — Voice of Precision */
    font-size: 11px;                /* --text-eyebrow */
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);       /* Muted — this label is not the headline */
    margin-bottom: var(--space-2);  /* 16px gap before section name */
  }

  /* ── Section name row (arrow + name) ──────────────────────────────────── */
  .up-next__name-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-2); /* 16px between arrow and name */
    margin-bottom: var(--space-2);
  }

  /* Arrow: azure — the single color of navigation and interactivity */
  .up-next__arrow {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--accent); /* #0082EB azure */
    flex-shrink: 0;
    /* Slight baseline alignment correction for arrow glyph */
    line-height: 1;
    padding-bottom: 1px;
  }

  /* Section name: serif weight — this is a destination, not a label */
  .up-next__section {
    font-family: var(--font-serif); /* Lora — the next section's headline voice */
    font-size: var(--text-h3);      /* clamp(1.125rem, 1.5vw, 1.5rem) */
    font-weight: 600;
    color: var(--text-primary);     /* #FAFAF8 bright white */
    line-height: var(--leading-tight);
  }

  /* ── Teaser text ───────────────────────────────────────────────────────── */
  .up-next__teaser {
    font-family: var(--font-sans);  /* Inter — body voice */
    font-size: var(--text-small);
    line-height: var(--leading-relaxed);
    color: var(--text-muted);
    margin: 0;
  }
</style>
