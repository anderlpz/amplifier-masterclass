---
/*
 * NumberedRow.astro — Numbered content row with hairline divider
 *
 * Used in technical sections for structured enumeration — kernel
 * responsibilities, module type features, key properties, etc.
 *
 * Layout: number (fixed width) | label + optional description
 * The number sits at the left margin in azure (the color of mechanism),
 * giving each row a visual anchor and a subtle azure rhythm as the
 * reader scans down the list.
 *
 * Props:
 *   number      — display number or label (e.g. "01", "02", or "—")
 *   label       — the primary row heading (bold)
 *   description — optional explanatory text below the label
 */
interface Props {
  number: string;
  label: string;
  description?: string;
}

const { number, label, description } = Astro.props;
---

<div class="numbered-row">
  <span class="numbered-row__number">{number}</span>
  <div class="numbered-row__content">
    <span class="numbered-row__label">{label}</span>
    {description && <p class="numbered-row__desc">{description}</p>}
  </div>
</div>

<style>
  /* ── Row container ─────────────────────────────────────────────────────── */
  .numbered-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);                         /* 24px between number and content */
    padding: var(--space-3) 0;                   /* 24px vertical rhythm */
    border-bottom: 1px solid var(--divider);     /* rgba(255,255,255,0.1) hairline */
  }

  /* First row: no top border (the section's own top border handles it) */
  .numbered-row:first-of-type {
    border-top: 1px solid var(--divider);
  }

  /* ── Number ────────────────────────────────────────────────────────────── */
  /*
   * Azure (--accent) signals this is a structured technical mechanism.
   * The number is in Space Grotesk — the Voice of Precision.
   * min-width ensures alignment when numbers go from single to double digit.
   */
  .numbered-row__number {
    font-family: var(--font-mono);  /* Space Grotesk — numeric precision */
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--accent);           /* #0082EB azure — technical accent */
    flex-shrink: 0;
    min-width: 2.5ch;               /* Holds alignment for up to "99" */
    line-height: var(--leading-normal);
  }

  /* ── Content block ─────────────────────────────────────────────────────── */
  .numbered-row__content {
    flex: 1;
    min-width: 0; /* Prevent flex overflow */
  }

  /* Label: Inter 600 — technical sub-heading voice */
  .numbered-row__label {
    display: block;
    font-family: var(--font-sans);  /* Inter — Voice of Structure */
    font-size: var(--text-body);
    font-weight: 600;
    color: var(--text-primary);     /* #FAFAF8 — bright on dark */
    line-height: var(--leading-normal);
  }

  /* Description: Inter 400, muted — explanatory, not primary */
  .numbered-row__desc {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 400;
    color: var(--text-muted);       /* #87867F — secondary, not competing with label */
    line-height: var(--leading-relaxed);
    margin: var(--space-1) 0 0 0;  /* 8px top gap from label */
    max-width: 60ch;                /* Comfortable reading measure for descriptions */
  }
</style>
