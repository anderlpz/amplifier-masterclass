---
interface Props {
  src?: string;
  alt?: string;
  caption?: string;
  width?: 'reading' | 'wide' | 'full';
}

const { src, alt = '', caption, width = 'wide' } = Astro.props;
const resolvedSrc = src ? `${import.meta.env.BASE_URL.replace(/\/$/, '')}${src}` : undefined;
---

<figure class:list={['diagram', `width-${width}`]}>
  <div class="diagram-inner">
    {src ? (
      <img src={resolvedSrc} alt={alt} loading="lazy" decoding="async" />
    ) : (
      <div class="diagram-svg">
        <slot />
      </div>
    )}
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .diagram {
    margin-bottom: var(--space-12);
  }

  .diagram-inner {
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    overflow: hidden;
  }

  img {
    width: 100%;
    height: auto;
    display: block;
  }

  .diagram-svg {
    width: 100%;
  }

  .diagram-svg :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }

  figcaption {
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--text-muted);
    text-align: center;
  }
</style>
