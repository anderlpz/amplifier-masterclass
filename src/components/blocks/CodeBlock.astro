---
interface Props {
  filename?: string;
  lang?: string;
}

const { filename, lang } = Astro.props;
const codeClass = lang ? `language-${lang}` : undefined;
---

<div class="code-block width-reading">
  {filename && <span class="filename">{filename}</span>}
  <pre><code class:list={[codeClass]}><slot /></code></pre>
</div>

<style>
  .code-block {
    position: relative;
    background: var(--bg-code);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    margin-bottom: var(--space-8);
    overflow-x: auto;
  }

  .filename {
    position: absolute;
    top: var(--space-3);
    right: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--text-muted);
    user-select: none;
  }

  pre {
    margin: 0;
    padding: 0;
    overflow-x: auto;
  }

  code {
    font-family: var(--font-code);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--text-primary);
    background: none;
    padding: 0;
    border-radius: 0;
  }
</style>
