---
interface Props {
  caption?: string;
}

const { caption } = Astro.props;
---

<div class="data-table width-wide">
  {caption && <p class="caption">{caption}</p>}
  <div class="table-wrapper">
    <slot />
  </div>
</div>

<style>
  .data-table {
    margin-bottom: var(--space-12);
  }

  .caption {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
    max-width: none;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  .table-wrapper :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }

  .table-wrapper :global(thead) {
    border-bottom: 2px solid var(--border-default);
  }

  .table-wrapper :global(th) {
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    text-align: left;
    padding: var(--space-3) var(--space-4);
    white-space: nowrap;
  }

  .table-wrapper :global(td) {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--border-default);
    color: var(--text-secondary);
    vertical-align: top;
    line-height: 1.5;
  }

  .table-wrapper :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .table-wrapper :global(tbody tr:hover) {
    background: var(--bg-muted);
  }
</style>
