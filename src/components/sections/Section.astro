---
/*
 * Section.astro — Foundation layer section wrapper
 * Rebuilt 2026-04-08 for iyo-clean aesthetic direction
 *
 * Two-zone architecture:
 *   section__entry  — iyo-clean first viewport (min-height: 100vh, almost all negative space)
 *   section__content — body content that appears below as reader scrolls
 *
 * Background variants (new names preferred; old names accepted for compatibility):
 *   "void"      (was "primary-dark")   — #0F0F13 cool near-black. Default.
 *   "slate"     (was "secondary-dark") — #161619 barely-different-from-void.
 *   "parchment" (was "palette-break")  — #F5F3EC warm cream. S03 and S12 only.
 *
 * Usage:
 *   <!-- Entry content (eyebrow + headline + lead) goes in named "entry" slot -->
 *   <!-- Body content goes in default slot -->
 *   <Section id="s04" label="The Kernel" background="void">
 *     <Fragment slot="entry">
 *       <Eyebrow label="THE KERNEL" />
 *       <h1>The center that holds still.</h1>
 *       <p class="lead">...</p>
 *     </Fragment>
 *     <div>... body content ...</div>
 *   </Section>
 *
 *   <!-- Existing sections with no named slot: all content → section__content.
 *        The section__entry zone becomes pure negative space (iyo-clean). -->
 */

interface Props {
  id: string;
  label: string;
  /** Background variant. New names preferred. Old names accepted for compatibility. */
  background?:
    | 'void'
    | 'slate'
    | 'parchment'
    | 'primary-dark'     /* legacy → void */
    | 'secondary-dark'   /* legacy → slate */
    | 'palette-break';   /* legacy → parchment */
  /** Extra CSS classes forwarded to the <section> element (e.g. "grain"). */
  class?: string;
}

const { id, label, background = 'void', class: extraClass } = Astro.props;

/* Normalize legacy prop names to new semantic class names */
const bgClass = (
  background === 'primary-dark'   ? 'void' :
  background === 'secondary-dark' ? 'slate' :
  background === 'palette-break'  ? 'parchment' :
  background
);

/* Parchment sections get the text-on-break class for color inheritance */
const isParchment = bgClass === 'parchment';
---

<section
  id={id}
  class:list={['section', `section--${bgClass}`, extraClass]}
  data-section={id}
  data-label={label}
  aria-label={label}
>
  <!--
    Entry viewport: the iyo-clean first screen.
    Contains exactly 3 visual groupings: Eyebrow → Headline → Lead.
    ~85% negative space. No body text, no diagrams, no structure.
    The reader arrives, orients, and breathes before content begins.

    When no "entry" slot is provided, this zone is pure background —
    which still achieves the iyo-clean pattern automatically.
  -->
  <div class={`section__entry${isParchment ? ' section__entry--parchment' : ''}`}>
    <div class="section__entry-inner">
      <slot name="entry" />
    </div>
  </div>

  <!--
    Content zone: appears below the entry as the reader scrolls.
    Max-width constrained, sidebar-offset on desktop.
    Density increases naturally below the entry viewport.
  -->
  <div class={`section__content${isParchment ? ' section__content--parchment' : ''}`}>
    <slot />
  </div>
</section>

<style>
  /* ─────────────────────────────────────────────
   * Section outer wrapper
   * ───────────────────────────────────────────── */
  .section {
    position: relative;
    width: 100%;
  }

  /* ─────────────────────────────────────────────
   * Background variants
   * ───────────────────────────────────────────── */
  .section--void {
    background-color: var(--bg-void);
    background-image:
      linear-gradient(rgba(0, 130, 235, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 130, 235, 0.035) 1px, transparent 1px);
    background-size: 60px 60px;
    color: var(--text-body);
  }

  .section--slate {
    background-color: var(--bg-slate);
    background-image:
      linear-gradient(rgba(0, 130, 235, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 130, 235, 0.035) 1px, transparent 1px);
    background-size: 60px 60px;
    color: var(--text-body);
  }

  .section--parchment {
    background-color: var(--bg-parchment);
    color: var(--text-on-break);
  }

  /* ─────────────────────────────────────────────
   * Entry viewport — the iyo-clean first screen
   *
   * min-height: 100vh ensures the first viewport is
   * almost entirely negative space (ground color).
   *
   * The 3-element cluster (eyebrow → headline → lead)
   * sits approximately 35% from the top.
   * justify-content: center + padding-top: 10vh
   * places the cluster slightly above true center,
   * creating visual weight toward the bottom.
   * ───────────────────────────────────────────── */
  .section__entry {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 10vh; /* shift cluster slightly above true center */
    padding-bottom: 0;
  }

  .section__entry-inner {
    /* Sidebar offset: content starts after TOC on desktop */
    padding-left: calc(var(--sidebar-width) + var(--space-8));
    padding-right: var(--space-6);
    max-width: calc(var(--content-max) + var(--sidebar-width) + var(--space-8));
  }

  /* ─────────────────────────────────────────────
   * Content zone — body below the entry viewport
   *
   * Max-width constraint keeps body copy at ~60-65ch.
   * Sidebar offset mirrors the entry zone on desktop.
   * ───────────────────────────────────────────── */
  .section__content {
    padding-left: calc(var(--sidebar-width) + var(--space-8));
    padding-right: var(--space-6);
    padding-top: var(--space-8);
    padding-bottom: var(--space-16); /* breathing room before next section */
    max-width: calc(var(--content-max) + var(--sidebar-width) + var(--space-8) + var(--space-6));
  }

  /* ─────────────────────────────────────────────
   * Parchment overrides
   *
   * On parchment, headlines and body text use --text-on-break.
   * h1, h2, h3 defaults from global.css use --text-primary
   * (dark-mode assumption), so we override here.
   * ───────────────────────────────────────────── */
  .section__entry--parchment :global(h1),
  .section__entry--parchment :global(h2),
  .section__entry--parchment :global(h3),
  .section__content--parchment :global(h1),
  .section__content--parchment :global(h2),
  .section__content--parchment :global(h3) {
    color: var(--text-on-break);
  }

  .section__entry--parchment :global(a),
  .section__content--parchment :global(a) {
    color: var(--accent);
  }

  /* ─────────────────────────────────────────────
   * Responsive — tablet and mobile
   *
   * Below 1024px: sidebar is hidden, so we remove the
   * sidebar offset and let content center naturally.
   * ───────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .section__entry-inner {
      padding-left: var(--space-6);
      max-width: var(--content-max);
      margin-inline: auto;
    }

    .section__content {
      padding-left: var(--space-4);
      padding-right: var(--space-4);
      max-width: var(--content-max);
      margin-inline: auto;
    }
  }

  @media (max-width: 767px) {
    .section__entry-inner {
      padding-left: var(--space-3);
      padding-right: var(--space-3);
    }

    .section__content {
      padding-left: var(--space-3);
      padding-right: var(--space-3);
      padding-bottom: var(--space-12);
    }
  }
</style>
